&lt;p&gt;&lt;img src=&quot;&#x2F;images&#x2F;img_2257238519d7de84.png&quot; alt=&quot;&quot; &#x2F;&gt;&lt;&#x2F;p&gt;
&lt;br&gt;
&lt;p&gt;참조&lt;br &#x2F;&gt;
&lt;a rel=&quot;external&quot; href=&quot;https:&#x2F;&#x2F;docs.opensearch.org&#x2F;latest&#x2F;vector-search&#x2F;performance-tuning-search&#x2F;&quot;&gt;https:&#x2F;&#x2F;docs.opensearch.org&#x2F;latest&#x2F;vector-search&#x2F;performance-tuning-search&#x2F;&lt;&#x2F;a&gt;&lt;&#x2F;p&gt;
